    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./",
    "resolveJsonModule": true
  },
  "include": [
    "./scripts",
    "./test",
    "./typechain-types"
  ]
